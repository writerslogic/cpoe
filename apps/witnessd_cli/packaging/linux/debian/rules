#!/usr/bin/make -f

# Debian rules file for witnessd

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_TERM_COLOR = never

# Version information
VERSION := $(shell dpkg-parsechangelog -S Version | cut -d- -f1)
COMMIT := $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_TIME := $(shell date -u +"%Y-%m-%dT%H:%M:%SZ")

%:
	dh $@

override_dh_auto_clean:
	cargo clean || true
	rm -rf bin/

override_dh_auto_build:
	# Build CLI binary
	cargo build --release --package witnessd_cli
	mkdir -p bin/
	cp target/release/witnessd bin/witnessd
	cp target/release/witnessd-native-messaging-host bin/ || true

override_dh_auto_test:
	cargo test --package witnessd_cli

override_dh_auto_install:
	# Install binaries
	install -D -m 755 bin/witnessd debian/witnessd/usr/bin/witnessd

	# Install man pages
	install -D -m 644 ../../docs/man/witnessd.1 debian/witnessd/usr/share/man/man1/witnessd.1

	# Install systemd units (if present)
	if [ -d packaging/linux/systemd ]; then \
		install -D -m 644 packaging/linux/systemd/witnessd.service debian/witnessd/lib/systemd/system/witnessd.service; \
		install -D -m 644 packaging/linux/systemd/witnessd-user.service debian/witnessd/usr/lib/systemd/user/witnessd.service; \
	fi

	# Install documentation
	install -D -m 644 ../../LICENSE debian/witnessd/usr/share/doc/witnessd/LICENSE
	install -D -m 644 README.md debian/witnessd/usr/share/doc/witnessd/README.md

override_dh_installsystemd:
	dh_installsystemd --name=witnessd
	dh_installsystemd --name=witnessd --user

override_dh_compress:
	dh_compress -X.md
