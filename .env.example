# CPOP Environment Variables
# Copy to .env and customize (never commit .env!)

# Database paths (defaults shown)
CPOP_EVENT_STORE=/home/user/.writerslogic/events.db
CPOP_MMR_PATH=/home/user/.writerslogic/mmr.bin
CPOP_CONFIG=/home/user/.writerslogic/config.toml

# Signing key path
CPOP_SIGNING_KEY=/home/user/.ssh/cpop_signing_key

# TPM configuration (optional)
CPOP_TPM_DEVICE=/dev/tpmrm0
CPOP_TPM_SIMULATOR=false
TPM2TOOLS_TCTI=device:/dev/tpmrm0

# External timestamping (optional)
CPOP_TSA_URL=https://freetsa.org/tsr
CPOP_OTS_CALENDAR=https://a.pool.opentimestamps.org

# Logging
CPOP_LOG_LEVEL=info
CPOP_AUDIT_LOG=/var/log/cpop/audit.log

# Development/testing
CPOP_DEBUG=false
CPOP_TEST_MODE=false
